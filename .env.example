# App
NEXT_PUBLIC_APP_NAME=FanModes
NEXT_PUBLIC_ENV=development

# Database (Postgres or Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/fanmodes

# Supabase (optional)
SUPABASE_URL=https://your-supabase-url
SUPABASE_ANON_KEY=anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key

# TxLINE integration
TXLINE_HOST=https://devnet.txline.example
TXLINE_GUEST_JWT_SECRET=replace_with_guest_jwt_secret
TXLINE_API_TOKEN=replace_with_api_token
TXLINE_DEFAULT_NETWORK=devnet
TXLINE_DEFAULT_TIER=worldcup-free

# Worker / Bot
WORKER_CONCURRENCY=4
BOT_TELEGRAM_TOKEN=telegram-bot-token
TTS_API_KEY=tts-service-key

# JWT / Auth
NEXTAUTH_SECRET=super-secret
